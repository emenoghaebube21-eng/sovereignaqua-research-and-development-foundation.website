# ==========================================================
# SovereignAqua Research & Development Foundation
# .gitignore
# ==========================================================

# ----------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# Linux
*~

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------

*.tmp
*.temp
*.bak
*.swp
*.swo
*.orig

# ----------------------------------------------------------
# IDE & Editor Settings
# ----------------------------------------------------------

.vscode/
.idea/
*.code-workspace

# Visual Studio
.vs/

# ----------------------------------------------------------
# Node.js
# ----------------------------------------------------------

node_modules/
.npm/
.pnpm-store/

# ----------------------------------------------------------
# Package Manager Caches
# ----------------------------------------------------------

.npmrc.local
.yarn-integrity

# ----------------------------------------------------------
# Build Output
# ----------------------------------------------------------

dist/
build/
out/
coverage/

# ----------------------------------------------------------
# Environment Files
# ----------------------------------------------------------

.env
.env.*
!.env.example

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------

.cache/
.parcel-cache/

# ----------------------------------------------------------
# Sass Cache
# ----------------------------------------------------------

.sass-cache/

# ----------------------------------------------------------
# Generated Source Maps
# ----------------------------------------------------------

*.map

# ----------------------------------------------------------
# Compressed Archives
# ----------------------------------------------------------

*.zip
*.tar
*.gz
*.7z

# ----------------------------------------------------------
# Local Database Files
# ----------------------------------------------------------

*.sqlite
*.db

# ----------------------------------------------------------
# Runtime Files
# ----------------------------------------------------------

*.pid
*.seed

# ----------------------------------------------------------
# Optional Media Exclusions
# Uncomment if you don't want to track generated media
# ----------------------------------------------------------

# asset/videos/generated/
# asset/images/temp/

# ----------------------------------------------------------
# Keep Placeholder Files
# ----------------------------------------------------------

!.gitkeep
